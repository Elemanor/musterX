---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Fast, insured handyman services across Toronto/GTA. Book a 2‑hour window or post your job to get licensed bids. Condo/office ready (COI, elevator bookings). Electrical (ESA), plumbing (306A), gas (TSSA) handled by licensed partners." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
<style is:global>
  @import '../styles/global.css';
</style>